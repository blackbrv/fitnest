generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id            String         @id @default(cuid())
  name          String
  email         String         @unique
  password      String
  avatar        String?        @db.MediumText
  bio           String?        @db.Text
  emailVerified       Boolean   @default(false) @map("email_verified")
  verificationToken   String?   @db.Text @map("verification_token")
  verificationExpiry  DateTime? @map("verification_expiry")
  resetToken          String?   @db.Text @map("reset_token")
  resetExpiry         DateTime? @map("reset_expiry")
  createdAt     DateTime       @default(now()) @map("created_at")
  updatedAt     DateTime       @updatedAt @map("updated_at")
  ownedFamilies Family[]       @relation("FamilyOwner")
  familyMembers FamilyMember[]
  notifications Notification[]
  workoutLogs   WorkoutLog[]

  @@map("users")
}

model Family {
  id           String         @id @default(cuid())
  familyName   String         @map("family_name")
  inviteCode   String         @unique @map("invite_code")
  ownerId      String         @map("owner_id")
  createdAt    DateTime       @default(now()) @map("created_at")
  updatedAt    DateTime       @updatedAt @map("updated_at")
  owner        User           @relation("FamilyOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  members      FamilyMember[]
  workoutPlans WorkoutPlan[]

  @@index([ownerId], map: "families_owner_id_fkey")
  @@map("families")
}

model FamilyMember {
  id       String     @id @default(cuid())
  familyId String     @map("family_id")
  userId   String     @map("user_id")
  role     MemberRole @default(MEMBER)
  joinedAt DateTime   @default(now()) @map("joined_at")
  family   Family     @relation(fields: [familyId], references: [id], onDelete: Cascade)
  user     User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([familyId, userId])
  @@index([userId], map: "family_members_user_id_fkey")
  @@map("family_members")
}

model WorkoutPlan {
  id            String            @id @default(cuid())
  familyId      String            @map("family_id")
  assignedTo    String?           @map("assigned_to")
  title         String
  description   String?           @db.Text
  difficulty    WorkoutDifficulty @default(BEGINNER)
  category      WorkoutCategory   @default(STRENGTH)
  scheduledDays String            @map("scheduled_days") @db.Text
  notes         String?           @db.Text
  isActive      Boolean           @default(true) @map("is_active")
  createdAt     DateTime          @default(now()) @map("created_at")
  updatedAt     DateTime          @updatedAt @map("updated_at")
  exercises     WorkoutExercise[]
  workoutLogs   WorkoutLog[]
  family        Family            @relation(fields: [familyId], references: [id], onDelete: Cascade)

  @@index([familyId], map: "workout_plans_family_id_fkey")
  @@map("workout_plans")
}

model WorkoutExercise {
  id            String      @id @default(cuid())
  workoutPlanId String      @map("workout_plan_id")
  exerciseName  String      @map("exercise_name")
  sets          Int
  reps          Int?
  duration      Int?
  restSeconds   Int?        @map("rest_seconds")
  order         Int         @default(0)
  workoutPlan   WorkoutPlan @relation(fields: [workoutPlanId], references: [id], onDelete: Cascade)

  @@index([workoutPlanId], map: "workout_exercises_workout_plan_id_fkey")
  @@map("workout_exercises")
}

model WorkoutLog {
  id            String        @id @default(cuid())
  userId        String        @map("user_id")
  workoutPlanId String        @map("workout_plan_id")
  status        WorkoutStatus @default(PENDING)
  completedAt   DateTime?     @map("completed_at")
  notes         String?       @db.Text
  createdAt     DateTime      @default(now()) @map("created_at")
  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  workoutPlan   WorkoutPlan   @relation(fields: [workoutPlanId], references: [id], onDelete: Cascade)

  @@index([userId], map: "workout_logs_user_id_fkey")
  @@index([workoutPlanId], map: "workout_logs_workout_plan_id_fkey")
  @@map("workout_logs")
}

model Notification {
  id        String           @id @default(cuid())
  userId    String           @map("user_id")
  type      NotificationType
  title     String
  message   String           @db.Text
  isRead    Boolean          @default(false) @map("is_read")
  createdAt DateTime         @default(now()) @map("created_at")
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId], map: "notifications_user_id_fkey")
  @@map("notifications")
}

enum MemberRole {
  OWNER
  MEMBER
}

enum WorkoutDifficulty {
  BEGINNER
  INTERMEDIATE
  ADVANCED
}

enum WorkoutCategory {
  STRENGTH
  CARDIO
  STRETCHING
  MOBILITY
  KIDS_EXERCISE
  RECOVERY
}

enum WorkoutStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  SKIPPED
}

enum NotificationType {
  WORKOUT_REMINDER
  STREAK_REMINDER
  FAMILY_ACTIVITY
  MISSED_WORKOUT
  GENERAL
}
